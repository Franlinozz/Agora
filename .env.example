# ============================================================
# Agora environment variables — copy to .env and fill in
# ============================================================

# --- Network: Arc testnet (primary chain) ---
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_ARC_AGENT_REGISTRY=
NEXT_PUBLIC_ARC_ESCROW_MANAGER=
NEXT_PUBLIC_ARC_REPUTATION_ORACLE=
ARC_DEPLOYER_PRIVATE_KEY=

# --- Network: Base mainnet ---
NEXT_PUBLIC_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
NEXT_PUBLIC_BASE_AGENT_REGISTRY=
NEXT_PUBLIC_BASE_ESCROW_MANAGER=
NEXT_PUBLIC_BASE_REPUTATION_ORACLE=
BASE_DEPLOYER_PRIVATE_KEY=

# --- Wallet/RPC keys ---
NEXT_PUBLIC_RAINBOWKIT_PROJECT_ID=
ALCHEMY_API_KEY=

# --- Backend services ---
POSTGRES_PASSWORD=
# URL-encoded version of POSTGRES_PASSWORD for Docker Compose DATABASE_URL interpolation.
# Example: if POSTGRES_PASSWORD is "p@ss word", set this to "p%40ss%20word".
POSTGRES_PASSWORD_URLENCODED=
DATABASE_URL=postgres://agora:agora@localhost:5432/agora
API_GATEWAY_PORT=4000
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_SECRET=
CLOUDFLARE_TUNNEL_TOKEN=
SENTRY_DSN=
DAEMON_MASTER_KEY=
AGENT_WORKER_COUNT=3
MEDIATOR_WORKER_COUNT=1

# --- AI providers ---
OPENAI_API_KEY=
AI_MEDIATOR_MODEL=gpt-4o-mini
AI_MEDIATOR_DAILY_CAP_CENTS=20

# --- AI mediator keypair (generated once, store securely) ---
MEDIATOR_PUBLIC_KEY=
MEDIATOR_SECRET_KEY=

# --- Optional: deferred integrations ---

# --- Logging / monitoring ---
LOG_LEVEL=info
NODE_ENV=development
