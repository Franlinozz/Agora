{
  "name": "@agora/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agora/shared": "workspace:*",
    "@agora/chains": "workspace:*",
    "@agora/sdk": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0",
    "viem": "^2.48.7",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@agora/eslint-config": "workspace:*",
    "@agora/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
